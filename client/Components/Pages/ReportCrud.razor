@page "/report-crud"
@using System.Net.Http.Json
@using System.Security.Claims
@using client.Services
@using Shared.Models
@attribute [Authorize]
@layout MainLayout
@inject AuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider

<h3>Reports</h3>
<AuthorizeView>
    <Authorized>
        @if (!string.IsNullOrEmpty(errorMessage) && !showForm)
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <button @onclick="NewReport" class="btn btn-primary mb-3">New Report</button>


        @if (reports == null)
        {
            <p><em>Loading reports...</em></p>
        }
        else if (reports.Count == 0)
        {
            <p><em>No reports available.</em></p>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in reports)
                    {
                        <tr>
                            <td>@report.title</td>
                            <td>@report.status</td>
                            <td>@report.submitted_at.ToString("g")</td>
                            <td>
                                <button @onclick="@(() => EditReport(report))" class="btn btn-warning">Edit</button>
                                <button @onclick="@(() => DeleteReport(report.report_id))"
                                        class="btn btn-danger">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @if (showForm)
        {
            <div style="border: 1px solid #ccc; padding: 10px; margin-top: 20px;">
                <EditForm Model="@currentReport" OnValidSubmit="@SaveReport" Context="editContext">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="form-group">
                        <label>Title</label>
                        <InputText @bind-Value="currentReport.title" class="form-control" />
                        <ValidationMessage For="@(() => currentReport.title)" />
                    </div>

                    <div class="form-group">
                        <label>Description</label>
                        <InputTextArea @bind-Value="currentReport.report_text" class="form-control" />
                        <ValidationMessage For="@(() => currentReport.report_text)" />
                    </div>
                    @*  
                        https://learn.microsoft.com/en-us/aspnet/core/mvc/models/file-uploads 
                        https://learn.microsoft.com/en-us/aspnet/core/blazor/file-uploads
                     *@
                    <div class="form-group mt-3">
                        <label>Files</label>
                        <InputFile OnChange="@OnFilesSelected" multiple class="form-control" />
                        @if (selectedFiles.Count > 0)
                        {
                            <ul class="mt-2">
                                @foreach (var file in selectedFiles)
                                {
                                    <li>@file.Name (@FormatFileSize(file.Size))</li>
                                }
                            </ul>
                        }
                    </div>

                    @if (isEditing)
                    {
                        <div class="form-group mt-3">
                            <label>Attached Files</label>
                            @if (attachedFiles.Count == 0)
                            {
                                <p><em>No files are attached to this report.</em></p>
                            }
                            else
                            {
                                <ul class="list-group">
                                    @foreach (var file in attachedFiles)
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center gap-3">
                                            <span>
                                                <strong>@file.file_name</strong>
                                                <small class="text-muted d-block">Uploaded @file.uploaded_at.ToString("g")</small>
                                            </span>
                                            <span class="btn-group">
                                                <button type="button"
                                                        class="btn btn-outline-secondary btn-sm"
                                                        @onclick="@(() => RemoveReportFileLink(file.file_id))">
                                                    Remove
                                                </button>
                                                <button type="button"
                                                        class="btn btn-outline-danger btn-sm"
                                                        @onclick="@(() => DeleteStoredFile(file.file_id))">
                                                    Delete File
                                                </button>
                                            </span>
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div style="color: red; margin: 10px 0;">@errorMessage</div>
                    }

                    <button type="submit" class="btn btn-success">Save</button>
                    <button type="button" @onclick="@Cancel" class="btn btn-secondary">Cancel</button>
                </EditForm>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <p>You need to log in to manage your reports.</p>
    </NotAuthorized>
</AuthorizeView>


@code {
    private List<Report>? reports;
    private Report currentReport = new()
    {
        title = string.Empty,
        report_text = string.Empty
    };
    private bool showForm;
    private bool isEditing;
    private string? errorMessage;
    private uint? currentUserId;
    private readonly List<IBrowserFile> selectedFiles = [];
    private List<FileSummary> attachedFiles = [];
    private const long MaxUploadBytes = 25 * 1024 * 1024;

    private HttpClient ApiClient => AuthService.CreateAuthorizedApiClient();

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUserId();
        await LoadReports();
    }

    private async Task LoadCurrentUserId()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdClaim = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (uint.TryParse(userIdClaim, out var userId))
        {
            currentUserId = userId;
        }
    }

    private async Task LoadReports()
    {
        if (currentUserId == null)
        {
            reports = [];
            errorMessage = "You need to be logged in to view your reports.";
            return;
        }

        try
        {
            reports = await ApiClient.GetFromJsonAsync<List<Report>>($"api/reports/user/{currentUserId}");
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading reports: {ex.Message}";
            reports = null;
        }
    }

    private void NewReport()
    {
        if (currentUserId == null)
        {
            errorMessage = "You need to be logged in before creating a report.";
            return;
        }

        currentReport = new Report()
        {
            submitted_by_user_id = currentUserId.Value,
            title = string.Empty,
            report_text = string.Empty,
            status = ReportStatus.submitted
        };
        showForm = true;
        isEditing = false;
        errorMessage = null;
        selectedFiles.Clear();
        attachedFiles = [];
    }

    private async Task EditReport(Report report)
    {
        try
        {
            var detail = await ApiClient.GetFromJsonAsync<ReportDetail>($"api/reports/{report.report_id}");
            if (detail == null)
            {
                errorMessage = "Unable to load report details.";
                return;
            }

            currentReport = new Report
            {
                report_id = detail.report_id,
                submitted_by_user_id = detail.submitted_by_user_id,
                title = detail.title,
                report_text = detail.report_text,
                status = detail.status,
                submitted_at = detail.submitted_at,
                updated_at = DateTime.UtcNow
            };

            attachedFiles = detail.Files;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading report details: {ex.Message}";
            return;
        }

        showForm = true;
        isEditing = true;
        errorMessage = null;
        selectedFiles.Clear();
    }

    private async Task SaveReport()
    {
        errorMessage = null;

        try
        {
            if (isEditing)
            {
                var response = await ApiClient.PutAsJsonAsync($"api/reports/{currentReport.report_id}", currentReport);
                response.EnsureSuccessStatusCode();
                await UploadSelectedFiles(currentReport.report_id);
            }
            else
            {
                var response = await ApiClient.PostAsJsonAsync("api/reports", currentReport);
                response.EnsureSuccessStatusCode();

                var createdReport = await response.Content.ReadFromJsonAsync<Report>();
                if (createdReport == null)
                {
                    throw new InvalidOperationException("The report was saved, but the server did not return it.");
                }

                await UploadSelectedFiles(createdReport.report_id);
            }

            await LoadReports();
            showForm = false;
            selectedFiles.Clear();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving report: {ex.Message}";
        }
    }

    private async Task DeleteReport(uint id)
    {
        try
        {
            await ApiClient.DeleteAsync($"api/reports/{id}");
            await LoadReports();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting report: {ex.Message}";
        }
    }

    private void Cancel()
    {
        showForm = false;
        errorMessage = null;
        selectedFiles.Clear();
        attachedFiles = [];
    }

    private void OnFilesSelected(InputFileChangeEventArgs args)
    {
        selectedFiles.Clear();
        selectedFiles.AddRange(args.GetMultipleFiles());
    }

    private async Task UploadSelectedFiles(uint reportId)
    {
        foreach (var selectedFile in selectedFiles)
        {
            if (selectedFile.Size > MaxUploadBytes)
            {
                throw new InvalidOperationException($"{selectedFile.Name} exceeds the 25 MB upload limit.");
            }

            using var content = new MultipartFormDataContent();
            using var stream = selectedFile.OpenReadStream(MaxUploadBytes);
            using var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
                string.IsNullOrWhiteSpace(selectedFile.ContentType)
                    ? "application/octet-stream"
                    : selectedFile.ContentType);

            content.Add(fileContent, "uploadedFile", selectedFile.Name);

            var response = await ApiClient.PostAsync($"api/files/upload?reportId={reportId}", content);
            response.EnsureSuccessStatusCode();
        }
    }

    private async Task RemoveReportFileLink(uint fileId)
    {
        try
        {
            var response = await ApiClient.DeleteAsync($"api/ReportFiles/{currentReport.report_id}/{fileId}");
            response.EnsureSuccessStatusCode();
            attachedFiles.RemoveAll(file => file.file_id == fileId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error removing file from report: {ex.Message}";
        }
    }

    private async Task DeleteStoredFile(uint fileId)
    {
        try
        {
            var response = await ApiClient.DeleteAsync($"api/files/{fileId}");
            response.EnsureSuccessStatusCode();
            attachedFiles.RemoveAll(file => file.file_id == fileId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting file: {ex.Message}";
        }
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes >= 1024 * 1024)
        {
            return $"{bytes / 1024d / 1024d:F1} MB";
        }

        if (bytes >= 1024)
        {
            return $"{bytes / 1024d:F1} KB";
        }

        return $"{bytes} B";
    }
}
