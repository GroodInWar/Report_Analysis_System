@page "/report-crud"
@using System.Net.Http.Json
@using System.Security.Claims
@using client.Services
@using Shared.Models
@attribute [Authorize]
@layout MainLayout
@inject AuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider

<h3>Reports</h3>
<AuthorizeView>
    <Authorized>
        @if (!string.IsNullOrEmpty(errorMessage) && !showForm)
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <button @onclick="NewReport" class="btn btn-primary mb-3">New Report</button>


        @if (reports == null)
        {
            <p><em>Loading reports...</em></p>
        }
        else if (reports.Count == 0)
        {
            <p><em>No reports available.</em></p>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in reports)
                    {
                        <tr>
                            <td>@report.title</td>
                            <td>@report.status</td>
                            <td>@report.submitted_at.ToString("g")</td>
                            <td>
                                <button @onclick="@(() => EditReport(report))" class="btn btn-warning">Edit</button>
                                <button @onclick="@(() => DeleteReport(report.report_id))"
                                        class="btn btn-danger">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @if (showForm)
        {
            <div style="border: 1px solid #ccc; padding: 10px; margin-top: 20px;">
                <EditForm Model="@currentReport" OnValidSubmit="@SaveReport" Context="editContext">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="form-group">
                        <label>Title</label>
                        <InputText @bind-Value="currentReport.title" class="form-control" />
                        <ValidationMessage For="@(() => currentReport.title)" />
                    </div>

                    <div class="form-group">
                        <label>Description</label>
                        <InputTextArea @bind-Value="currentReport.report_text" class="form-control" />
                        <ValidationMessage For="@(() => currentReport.report_text)" />
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div style="color: red; margin: 10px 0;">@errorMessage</div>
                    }

                    <button type="submit" class="btn btn-success">Save</button>
                    <button type="button" @onclick="@Cancel" class="btn btn-secondary">Cancel</button>
                </EditForm>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <p>You need to log in to manage your reports.</p>
    </NotAuthorized>
</AuthorizeView>


@code {
    private List<Report>? reports;
    private Report currentReport = new()
    {
        title = string.Empty,
        report_text = string.Empty
    };
    private bool showForm;
    private bool isEditing;
    private string? errorMessage;
    private uint? currentUserId;

    private HttpClient ApiClient => AuthService.CreateAuthorizedApiClient();

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUserId();
        await LoadReports();
    }

    private async Task LoadCurrentUserId()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdClaim = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (uint.TryParse(userIdClaim, out var userId))
        {
            currentUserId = userId;
        }
    }

    private async Task LoadReports()
    {
        if (currentUserId == null)
        {
            reports = [];
            errorMessage = "You need to be logged in to view your reports.";
            return;
        }

        try
        {
            reports = await ApiClient.GetFromJsonAsync<List<Report>>($"api/reports/user/{currentUserId}");
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading reports: {ex.Message}";
            reports = null;
        }
    }

    private void NewReport()
    {
        if (currentUserId == null)
        {
            errorMessage = "You need to be logged in before creating a report.";
            return;
        }

        currentReport = new Report()
        {
            submitted_by_user_id = currentUserId.Value,
            title = string.Empty,
            report_text = string.Empty,
            status = ReportStatus.submitted
        };
        showForm = true;
        isEditing = false;
        errorMessage = null;
    }

    private void EditReport(Report report)
    {
        currentReport = new Report
        {
            report_id = report.report_id,
            submitted_by_user_id = report.submitted_by_user_id,
            title = report.title,
            report_text = report.report_text,
            status = report.status,
            submitted_at = report.submitted_at,
            updated_at = DateTime.UtcNow
        };

        showForm = true;
        isEditing = true;
        errorMessage = null;
    }

    private async Task SaveReport()
    {
        errorMessage = null;

        try
        {
            if (isEditing)
            {
                await ApiClient.PutAsJsonAsync($"api/reports/{currentReport.report_id}", currentReport);
            }
            else
            {
                await ApiClient.PostAsJsonAsync("api/reports", currentReport);
            }

            await LoadReports();
            showForm = false;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving report: {ex.Message}";
        }
    }

    private async Task DeleteReport(uint id)
    {
        try
        {
            await ApiClient.DeleteAsync($"api/reports/{id}");
            await LoadReports();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting report: {ex.Message}";
        }
    }

    private void Cancel()
    {
        showForm = false;
        errorMessage = null;
    }
}
