@page "/reports/{ReportId:int}"
@attribute [Authorize]
@layout MainLayout
@using client.Services
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<h3>Report Details</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (report == null)
{
    <p><em>Loading report...</em></p>
}
else
{
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h4 class="mb-1">@report.title</h4>
            <div class="text-muted small">
                Report #@report.report_id &middot; @report.status &middot; Submitted @report.submitted_at.ToString("g")
            </div>
        </div>

        <AuthorizeView Roles="Analyst,analyst">
            <Authorized>
                <div class="btn-group">
                    @if (report.incident_id == null)
                    {
                        <button type="button" class="btn btn-success" @onclick="CreateIncident">Open Incident</button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary" @onclick="ViewLinkedIncident">View Incident</button>
                    }
                    <button type="button" class="btn btn-outline-secondary" @onclick="BackToOpenReports">Open Reports</button>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>

    <p>@report.report_text</p>

    <dl class="row">
        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@report.status</dd>

        <dt class="col-sm-3">Submitted</dt>
        <dd class="col-sm-9">@report.submitted_at.ToString("g")</dd>

        <dt class="col-sm-3">Updated</dt>
        <dd class="col-sm-9">@report.updated_at?.ToString("g")</dd>
    </dl>

    <section class="mt-4">
        <h4>Reporter</h4>
        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@ReporterName</dd>

            <dt class="col-sm-3">User ID</dt>
            <dd class="col-sm-9">#@report.submitted_by_user_id</dd>

            @if (!string.IsNullOrWhiteSpace(report.SubmittedByUser?.email))
            {
                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@report.SubmittedByUser.email</dd>
            }
        </dl>
    </section>

    <section class="mt-4">
        <h4>Files</h4>
        @if (report.Files.Count == 0)
        {
            <p><em>No files are attached to this report.</em></p>
        }
        else
        {
            <ul class="list-group">
                @foreach (var file in report.Files)
                {
                    <li class="list-group-item">
                        <div class="d-flex w-100 justify-content-between">
                            <strong>@file.file_name</strong>
                            <small class="text-muted">Uploaded @file.uploaded_at.ToString("g")</small>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(file.file_hash))
                        {
                            <small class="text-muted">SHA-256: @file.file_hash</small>
                        }
                    </li>
                }
            </ul>
        }
    </section>

    <section class="mt-4">
        <h4>Linked Incident</h4>
        @if (linkedIncidentLoading)
        {
            <p><em>Loading linked incident...</em></p>
        }
        else if (!string.IsNullOrEmpty(linkedIncidentError))
        {
            <div class="alert alert-warning">@linkedIncidentError</div>
        }
        else if (linkedIncident == null)
        {
            <div class="alert alert-secondary mb-0">No incident is currently linked to this report.</div>
        }
        else
        {
            <div class="list-group">
                <a class="list-group-item list-group-item-action" href="@($"/incidents/{linkedIncident.incident_id}")">
                    <div class="d-flex w-100 justify-content-between">
                        <strong>#@linkedIncident.incident_id @linkedIncident.incident_title</strong>
                        <small>@IncidentStatus</small>
                    </div>
                    <small class="text-muted">Updated @linkedIncident.updated_at.ToString("g")</small>
                    <p class="mb-0 mt-2">@linkedIncident.incident_description</p>
                </a>
            </div>
        }
    </section>

    <section class="mt-4">
        <h4>Comments</h4>
        @if (linkedIncident?.Comments.Count > 0)
        {
            <div class="list-group">
                @foreach (var comment in linkedIncident.Comments)
                {
                    <div class="list-group-item">
                        <div class="d-flex w-100 justify-content-between">
                            <strong>@DisplayName(comment.User, $"User #{comment.user_id}")</strong>
                            <small>@comment.created_at.ToString("g")</small>
                        </div>
                        <p class="mb-0">@comment.comment_text</p>
                    </div>
                }
            </div>
        }
        else
        {
            <p><em>No comments are visible for this report.</em></p>
        }
    </section>
}

@code {
    [Parameter]
    public int ReportId { get; set; }

    private ReportDetail? report;
    private IncidentDetail? linkedIncident;
    private string? errorMessage;
    private string? linkedIncidentError;
    private bool linkedIncidentLoading;
    private string ReporterName => DisplayName(report?.SubmittedByUser, $"User #{report?.submitted_by_user_id}");
    private string IncidentStatus => linkedIncident?.resolved_at == null ? "Open" : "Resolved";

    private HttpClient ApiClient => AuthService.CreateAuthorizedApiClient();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            report = await ApiClient.GetFromJsonAsync<ReportDetail>($"api/reports/{ReportId}");
            await LoadLinkedIncident();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading report: {ex.Message}";
        }
    }

    private async Task LoadLinkedIncident()
    {
        if (report?.incident_id == null)
        {
            return;
        }

        try
        {
            linkedIncidentLoading = true;
            linkedIncident = await ApiClient.GetFromJsonAsync<IncidentDetail>($"api/incidents/{report.incident_id}");
        }
        catch (Exception ex)
        {
            linkedIncidentError = $"Unable to load linked incident: {ex.Message}";
        }
        finally
        {
            linkedIncidentLoading = false;
        }
    }

    private void CreateIncident()
    {
        NavigationManager.NavigateTo($"/incidents/create?sourceReportId={ReportId}");
    }

    private void ViewLinkedIncident()
    {
        if (report?.incident_id != null)
        {
            NavigationManager.NavigateTo($"/incidents/{report.incident_id}");
        }
    }

    private void BackToOpenReports()
    {
        NavigationManager.NavigateTo("/open-reports");
    }

    private static string DisplayName(UserSummary? user, string fallback)
    {
        if (user == null)
        {
            return fallback;
        }

        var fullName = $"{user.first_name} {user.last_name}".Trim();
        if (!string.IsNullOrWhiteSpace(fullName))
        {
            return fullName;
        }

        return string.IsNullOrWhiteSpace(user.username) ? fallback : user.username;
    }

    private static string DisplayName(User? user, string fallback)
    {
        if (user == null)
        {
            return fallback;
        }

        var fullName = $"{user.first_name} {user.last_name}".Trim();
        if (!string.IsNullOrWhiteSpace(fullName))
        {
            return fullName;
        }

        return string.IsNullOrWhiteSpace(user.username) ? fallback : user.username;
    }

    private sealed class ReportDetail : Report
    {
        public List<FileSummary> Files { get; set; } = [];
    }

    private sealed class IncidentDetail : Incident
    {
        public List<CommentSummary> Comments { get; set; } = [];
        public List<FileSummary> Files { get; set; } = [];
    }

    private sealed class UserSummary
    {
        public uint user_id { get; set; }
        public string first_name { get; set; } = "";
        public string last_name { get; set; } = "";
        public string username { get; set; } = "";
        public string email { get; set; } = "";
    }

    private sealed class CommentSummary
    {
        public uint user_id { get; set; }
        public UserSummary? User { get; set; }
        public string comment_text { get; set; } = "";
        public DateTime created_at { get; set; }
    }

    private sealed class FileSummary
    {
        public string file_name { get; set; } = "";
        public string file_hash { get; set; } = "";
        public DateTime uploaded_at { get; set; }
    }
}
