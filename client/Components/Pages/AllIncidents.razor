@page "/incidents"
@layout MainLayout
@inject IHttpClientFactory HttpFactory
@inject NavigationManager NavigationManager

<h3>All Incidents</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (incidents == null)
{
    <p><em>Loading incidents...</em></p>
}
else if (incidents.Count == 0)
{
    <p><em>No incidents available.</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Category</th>
                <th>Severity</th>
                <th>Created</th>
                <th>Updated</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var incident in incidents)
            {
                <tr>
                    <td>@incident.incident_title</td>
                    <td>@(incident.Category?.category_name ?? incident.category_id.ToString())</td>
                    <td>@(incident.Severity?.severity_name ?? incident.severity_id.ToString())</td>
                    <td>@incident.created_at.ToString("g")</td>
                    <td>@incident.updated_at.ToString("g")</td>
                    <td>
                        <button class="btn btn-info" @onclick="@(() => NavigationManager.NavigateTo($"/incidents/{incident.incident_id}"))">View</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<IncidentListItem>? incidents;
    private string? errorMessage;

    private HttpClient ApiClient => HttpFactory.CreateClient("Api");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await ApiClient.GetFromJsonAsync<PagedIncidentResponse>("api/incidents");
            incidents = response?.items ?? [];
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading incidents: {ex.Message}";
            incidents = [];
        }
    }

    private sealed class PagedIncidentResponse
    {
        public int page { get; set; }
        public int pageSize { get; set; }
        public int totalCount { get; set; }
        public int totalPages { get; set; }
        public List<IncidentListItem> items { get; set; } = [];
    }

    private sealed class IncidentListItem
    {
        public uint incident_id { get; set; }
        public uint? CreatedByUserId { get; set; }
        public UserSummary? CreatedByUser { get; set; }
        public uint category_id { get; set; }
        public CategoryLookup? Category { get; set; }
        public uint severity_id { get; set; }
        public SeverityLookup? Severity { get; set; }
        public string incident_title { get; set; } = "";
        public string? incident_description { get; set; }
        public DateTime created_at { get; set; }
        public DateTime updated_at { get; set; }
        public DateTime? resolved_at { get; set; }
        public bool CanEdit { get; set; }
        public bool IsOwner { get; set; }
        public bool IsReadOnly { get; set; }
    }
}
