@page "/open-reports"
@attribute [Authorize(Roles = "Analyst,analyst")]
@using client.Services
@layout MainLayout
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<h3>Open Reports</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (openReports == null)
{
    <p><em>Loading open reports...</em></p>
}
else if (openReports.Count == 0)
{
    <p><em>No open reports available.</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Status</th>
                <th>Submitted</th>
                <th>Updated</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var report in openReports)
            {
                <tr>
                    <td>@report.title</td>
                    <td>@report.status</td>
                    <td>@report.submitted_at.ToString("g")</td>
                    <td>@report.updated_at?.ToString("g")</td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <button @onclick="@(() => ViewReport(report.report_id))" class="btn btn-info">View</button>
                            @if (report.incident_id == null)
                            {
                                <button @onclick="@(() => OpenIncident(report.report_id))" class="btn btn-success">Open Incident</button>
                            }
                            <button @onclick="@(() => UpdateReportStatus(report.report_id, ReportStatus.under_review))" class="btn btn-outline-primary">Review</button>
                            <button @onclick="@(() => UpdateReportStatus(report.report_id, ReportStatus.rejected))" class="btn btn-outline-danger">Reject</button>
                            <button @onclick="@(() => UpdateReportStatus(report.report_id, ReportStatus.closed))" class="btn btn-outline-secondary">Close</button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (selectedReport != null)
    {
        <div class="border rounded p-3 mt-3">
            <div class="d-flex justify-content-between align-items-start gap-3">
                <div>
                    <h4 class="mb-1">@selectedReport.title</h4>
                    <div class="text-muted small">
                        Report #@selectedReport.report_id &middot; @selectedReport.status &middot;
                        Submitted @selectedReport.submitted_at.ToString("g")
                    </div>
                </div>
                <button type="button" class="btn-close" aria-label="Close" @onclick="ClearSelectedReport"></button>
            </div>

            <p class="mt-3">@selectedReport.report_text</p>

            @if (linkedIncidentLoading)
            {
                <p><em>Loading linked incident...</em></p>
            }
            else if (!string.IsNullOrEmpty(linkedIncidentError))
            {
                <div class="alert alert-warning">@linkedIncidentError</div>
            }
            else if (linkedIncident != null)
            {
                <div class="alert alert-info mb-0">
                    <div class="fw-semibold">
                        Linked to
                        <a href="@($"/incidents/{linkedIncident.incident_id}")">
                            incident #@linkedIncident.incident_id: @linkedIncident.incident_title
                        </a>
                    </div>
                    <div class="small text-muted">
                        Updated @linkedIncident.updated_at.ToString("g")
                    </div>
                    <p class="mb-0 mt-2">@linkedIncident.incident_description</p>
                </div>
            }
            else
            {
                <div class="alert alert-secondary">
                    No incident is currently linked to this report.
                </div>

                @if (linkableIncidents.Count > 0)
                {
                    <div class="input-group">
                        <select class="form-select" @bind="selectedIncidentToLink">
                            <option value="0">Choose an existing incident...</option>
                            @foreach (var incident in linkableIncidents)
                            {
                                <option value="@incident.incident_id">#@incident.incident_id @incident.incident_title</option>
                            }
                        </select>
                        <button type="button" class="btn btn-outline-primary" @onclick="LinkSelectedReportToIncident">
                            Link Report
                        </button>
                    </div>
                }
            }
        </div>
    }
}

@code {
    private List<Report>? openReports;
    private Report? selectedReport;
    private Incident? linkedIncident;
    private List<IncidentListItem> linkableIncidents = [];
    private uint selectedIncidentToLink;
    private string? errorMessage;
    private string? linkedIncidentError;
    private bool linkedIncidentLoading;

    private HttpClient ApiClient => AuthService.CreateAuthorizedApiClient();

    protected override async Task OnInitializedAsync()
    {
        await LoadReports();
        await LoadLinkableIncidents();
    }

    private async Task LoadReports()
    {
        try
        {
            var reports = await ApiClient.GetFromJsonAsync<List<Report>>("api/reports") ?? [];
            openReports = reports
                .Where(report => report.status is not ReportStatus.closed and not ReportStatus.rejected)
                .OrderByDescending(report => report.submitted_at)
                .ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading open reports: {ex.Message}";
            openReports = [];
        }
    }

    private async Task LoadLinkableIncidents()
    {
        try
        {
            var response = await ApiClient.GetFromJsonAsync<PagedIncidentResponse>("api/incidents?pageSize=100&resolved=false");
            linkableIncidents = response?.items ?? [];
            selectedIncidentToLink = linkableIncidents.FirstOrDefault()?.incident_id ?? 0;
        }
        catch
        {
            linkableIncidents = [];
            selectedIncidentToLink = 0;
        }
    }

    private async Task ViewReport(uint reportId)
    {
        selectedReport = null;
        linkedIncident = null;
        linkedIncidentError = null;
        linkedIncidentLoading = false;
        errorMessage = null;

        try
        {
            selectedReport = await ApiClient.GetFromJsonAsync<Report>($"api/reports/{reportId}");

            if (selectedReport?.incident_id == null)
            {
                return;
            }

            linkedIncidentLoading = true;
            linkedIncident = await ApiClient.GetFromJsonAsync<Incident>($"api/incidents/{selectedReport.incident_id}");
        }
        catch (Exception ex)
        {
            if (selectedReport == null)
            {
                errorMessage = $"Error loading report details: {ex.Message}";
            }
            else
            {
                linkedIncidentError = $"Unable to load linked incident: {ex.Message}";
            }
        }
        finally
        {
            linkedIncidentLoading = false;
        }
    }

    private void ClearSelectedReport()
    {
        selectedReport = null;
        linkedIncident = null;
        linkedIncidentError = null;
        selectedIncidentToLink = linkableIncidents.FirstOrDefault()?.incident_id ?? 0;
    }

    private void OpenIncident(uint reportId)
    {
        NavigationManager.NavigateTo($"/incidents/create?sourceReportId={reportId}");
    }

    private async Task UpdateReportStatus(uint reportId, ReportStatus status)
    {
        try
        {
            var response = await ApiClient.PatchAsJsonAsync($"api/reports/{reportId}/status", new { status });
            response.EnsureSuccessStatusCode();
            await LoadReports();

            if (selectedReport?.report_id == reportId)
            {
                await ViewReport(reportId);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating report status: {ex.Message}";
        }
    }

    private async Task LinkSelectedReportToIncident()
    {
        if (selectedReport == null || selectedIncidentToLink == 0)
        {
            return;
        }

        try
        {
            var response = await ApiClient.PostAsync(
                $"api/reports/{selectedReport.report_id}/link-incident/{selectedIncidentToLink}",
                content: null);
            response.EnsureSuccessStatusCode();

            await LoadReports();
            await ViewReport(selectedReport.report_id);
        }
        catch (Exception ex)
        {
            linkedIncidentError = $"Error linking report to incident: {ex.Message}";
        }
    }

    private sealed class PagedIncidentResponse
    {
        public List<IncidentListItem> items { get; set; } = [];
    }

    private sealed class IncidentListItem
    {
        public uint incident_id { get; set; }
        public string incident_title { get; set; } = "";
    }
}
